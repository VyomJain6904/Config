# Font
font-family = JetBrainsMono Nerd Font
font-size = 12
bold-is-bright = true

theme=Charcoal

# Cursor Style
cursor-style = bar

# UI Clean look

# Scroll
scrollback-limit = 1000000000

# ---------- KEYBINDS ----------

keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = performable:ctrl+shift+s=new_split:right
keybind = performable:ctrl+shift+d=new_split:down
keybind = performable:ctrl+alt+a=prompt_surface_title
keybind = performable:ctrl+w=close_surface
