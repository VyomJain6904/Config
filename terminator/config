[global_config]
  enabled_plugins = MavenPluginURLHandler, LaunchpadBugURLHandler, LaunchpadCodeURLHandler, APTURLHandler, Logger, TerminalShot
  ask_before_closing = never
[keybindings]
  cycle_next = <Primary>grave
  split_horiz = <Primary><Shift>h
  split_vert = <Primary><Shift>v
  close_term = <Primary>w
  copy = <Primary>c
  paste = <Primary>v
  close_window = <Primary>q
  next_tab = <Primary>Tab
[profiles]
  [[default]]

    # Font
    use_system_font = False
    font = JetBrainsMonoNL Nerd Font Propo Semi-Bold 10

    # Background
    background_color = "#000000"
    background_darkness = 0.95

    # Foreground
    foreground_color = "#f8f8f2"

    # Cursor
    cursor_shape = ibeam
    cursor_color_default = False
    cursor_fg_color = "#282a36"
    cursor_bg_color = "#f8f8f2"

    # Window
    show_titlebar = False
    borderless = True
    scrollbar_position = hidden

    # Scrollback
    scrollback_infinite = True
    scroll_on_output = False
    scroll_on_keystroke = True

    # Bell
    audible_bell = False
    visible_bell = False
    urgent_bell = False

    # Palette
    palette = "#000000:#ff5555:#50fa7b:#f1fa8c:#bd93f9:#ff79c6:#8be9fd:#f8f8f2:#6272a4:#ff6e6e:#69ff94:#ffffa5:#d6acff:#ff92df:#a4ffff:#ffffff"

    # Extras
    bold_is_bright = True
    title_hide_sizetext = True
    copy_on_selection = False

[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""

    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default

[plugins]
